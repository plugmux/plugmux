    {
      "id": "claude-code",
      "name": "Claude Code",
      "icon": "claudecode",
      "config_format": "json",
      "mcp_key": "mcpServers",
      "tier": "auto",
      "install_url": "https://docs.anthropic.com/en/docs/claude-code/overview",
      "setup_hint": "Add the plugmux entry to your ~/.claude.json file under mcpServers.",
      "config_paths": {
        "macos": "~/.claude.json",
        "linux": "~/.claude.json",
        "windows": "%USERPROFILE%\\.claude.json"
      }
    },
    {
      "id": "claude-desktop",
      "name": "Claude Desktop",
      "icon": "claude",
      "config_format": "json",
      "mcp_key": "mcpServers",
      "tier": "auto",
      "supported_transports": ["stdio"],
      "install_url": "https://claude.ai/download",
      "setup_hint": "Add the plugmux entry to claude_desktop_config.json. Note: Claude Desktop only supports stdio transport.",
      "config_paths": {
        "macos": "~/Library/Application Support/Claude/claude_desktop_config.json",
        "linux": "~/.config/Claude/claude_desktop_config.json",
        "windows": "%APPDATA%\\Claude\\claude_desktop_config.json"
      }
    },
